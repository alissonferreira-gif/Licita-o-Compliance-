rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Qualquer usuário autenticado pode ler números reportados
    match /reported_numbers/{number} {
      allow read: if request.auth != null;
      allow write: if false; // apenas Cloud Functions escrevem
    }

    // Usuário só pode criar reportes próprios
    match /user_reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.uid
                    && validateReport(request.resource.data);
    }

    // Stats globais: leitura autenticada, escrita só via Cloud Function
    match /app_stats/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Metadados de usuário: usuário lê/escreve só os próprios dados
    match /users_meta/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // apenas Cloud Functions escrevem
    }

    function validateReport(data) {
      return data.number is string
        && data.number.matches('^\\+55[0-9]{10,11}$')
        && data.type in ['telemarketing', 'fraud', 'debt_collection', 'robocall', 'no_hangup', 'other']
        && (!('comment' in data) || (data.comment is string && data.comment.size() <= 200))
        && data.user_id is string
        && data.created_at is timestamp;
    }
  }
}
